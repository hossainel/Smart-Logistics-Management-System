<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainBorderPane" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/1" fx:controller="com.example.smartlogisticssystem.controller.DashboardController">

    <left>
        <VBox prefWidth="240.0" spacing="6.0" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="25.0" />
            </padding>
            <children>
                <Label text="Smart Logistics" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Label text="Management System v1.0" textFill="#95a5a6">
                    <font>
                        <Font size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="15.0" />
                    </VBox.margin>
                </Label>

                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowOverview" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="📊  Overview" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowParcels" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="📦  Parcels" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowCustomers" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="👥  Customers" />

                <Separator opacity="0.15" prefWidth="200.0" />

                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowWarehouses" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="🏭  Warehouses" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowLocations" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="📍  Locations" />

                <Separator opacity="0.15" prefWidth="200.0" />

                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowDrivers" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="🪪  Drivers" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowVehicles" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="🚛  Vehicles" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowAssignments" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="🔗  Fleet Pairing" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowDispatches" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="📅  Dispatches" />

                <Separator opacity="0.15" prefWidth="200.0" />

                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowBilling" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="💰  Billing" />
                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleShowTracking" prefHeight="36.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="🔍  Tracking" />

                <Separator opacity="0.15" prefWidth="200.0">
                    <VBox.margin>
                        <Insets bottom="10.0" top="15.0" />
                    </VBox.margin>
                </Separator>

                <Button maxWidth="Infinity" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleLogout" prefHeight="38.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;" text="🚪  Logout Session" />
            </children>
        </VBox>
    </left>

    <center>
    </center>
</BorderPane>
