<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="810.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/1" fx:controller="com.example.smartlogisticssystem.controller.WarehouseController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox prefWidth="260.0" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 6;">
                    <children>
                        <Label text="Provision Warehouse" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Warehouse Name:" />
                                <TextField fx:id="warehouseNameField" promptText="e.g., Sector 4 Hub" prefHeight="35.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Location/Address:" />
                                <TextField fx:id="locationField" promptText="City coordinates..." prefHeight="35.0" />
                            </children>
                        </VBox>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#addWarehouse" prefHeight="35.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white;" text="Register Hub" />
                    </children>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="10.0">
                    <children>
                        <Label text="Infrastructure Network Nodes" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TableView fx:id="warehouseTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="80.0" text="Node ID" />
                                <TableColumn fx:id="colName" prefWidth="220.0" text="Facility Name" />
                                <TableColumn fx:id="colLocation" prefWidth="230.0" text="Physical Address" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>