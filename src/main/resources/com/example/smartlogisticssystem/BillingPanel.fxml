<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="810.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/1" fx:controller="com.example.smartlogisticssystem.controller.BillingController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox prefWidth="260.0" spacing="12.0" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 6;">
                    <children>
                        <Label text="Process Invoicing" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Tracking Reference:" />
                                <TextField fx:id="trackingIdField" promptText="TRK-XXXXXXXX" prefHeight="30.0" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Customer Account ID:" />
                                <TextField fx:id="customerIdField" promptText="Numeric Key..." prefHeight="30.0" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Base Transit Fare ($):" />
                                <TextField fx:id="fareField" promptText="00.00" prefHeight="30.0" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Payment Method:" />
                                <ComboBox fx:id="methodCombo" maxWidth="Infinity" prefHeight="30.0" promptText="Select Option..." />
                            </children>
                        </VBox>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCreateInvoice" prefHeight="35.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white;" text="Post Transaction" />
                    </children>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="10.0">
                    <children>
                        <Label text="Financial Ledger &amp; Billings Transactions" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TableView fx:id="billingTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colInvoiceId" prefWidth="80.0" text="Invoice ID" />
                                <TableColumn fx:id="colTrackId" prefWidth="150.0" text="Tracking Code" />
                                <TableColumn fx:id="colAmount" prefWidth="150.0" text="Total Charged" />
                                <TableColumn fx:id="colStatus" prefWidth="150.0" text="Payment Status" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>