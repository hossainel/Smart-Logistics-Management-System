<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/1" fx:controller="com.example.smartlogisticssystem.controller.FleetAssignmentController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="🚛 Fleet Assignment Management" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox prefWidth="280.0" spacing="12.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                            <children>
                                <Label text="Deploy Asset Link" textFill="#34495e">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Vehicle ID" textFill="#7f8c8d" />
                                        <TextField fx:id="vehicleIdField" promptText="Enter Vehicle ID Number" prefHeight="35.0" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Driver ID" textFill="#7f8c8d" />
                                        <TextField fx:id="driverIdField" promptText="Enter Driver ID Number" prefHeight="35.0" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Deployment Status" textFill="#7f8c8d" />
                                        <ComboBox fx:id="statusCombo" maxWidth="Infinity" prefHeight="35.0" promptText="Select Status" />
                                    </children>
                                </VBox>

                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSaveAssignment" prefHeight="38.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Confirm Assignment" />
                            </children>
                        </VBox>

                        <TableView fx:id="assignmentTable" HBox.hgrow="ALWAYS" style="-fx-background-radius: 5;">
                            <columns>
                                <TableColumn fx:id="colAssignmentId" prefWidth="90.0" text="Assignment ID" />
                                <TableColumn fx:id="colVehicleId" prefWidth="110.0" text="Vehicle ID" />
                                <TableColumn fx:id="colDriverId" prefWidth="110.0" text="Driver ID" />
                                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>