<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="810.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/1" fx:controller="com.example.smartlogisticssystem.controller.ParcelController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox prefWidth="260.0" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 6;">
                    <children>
                        <Label text="Register New Shipment" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Sender Name:" />
                                <TextField fx:id="senderField" promptText="Enter shipper..." prefHeight="35.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Receiver Name:" />
                                <TextField fx:id="receiverField" promptText="Enter consignee..." prefHeight="35.0" />
                            </children>
                        </VBox>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleAddParcel" prefHeight="35.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white;" text="Add Parcel" />
                    </children>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="10.0">
                    <children>
                        <Label text="Active Shipments Registry Ledger" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TableView fx:id="parcelTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTrackingId" prefWidth="130.0" text="Tracking ID" />
                                <TableColumn fx:id="colSender" prefWidth="130.0" text="Sender" />
                                <TableColumn fx:id="colReceiver" prefWidth="130.0" text="Receiver" />
                                <TableColumn fx:id="colStatus" prefWidth="140.0" text="Status" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>