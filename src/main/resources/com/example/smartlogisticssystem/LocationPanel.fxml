<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="810.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/1" fx:controller="com.example.smartlogisticssystem.controller.LocationController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox prefWidth="260.0" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 6;">
                    <children>
                        <Label text="Add Network Node" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Facility Name:" />
                                <TextField fx:id="locationNameField" promptText="e.g., Central Sorting Hub" prefHeight="35.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="City Location:" />
                                <TextField fx:id="cityField" promptText="Enter city location..." prefHeight="35.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="State / Region:" />
                                <TextField fx:id="stateField" promptText="Enter state/region..." prefHeight="35.0" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Infrastructure Node Type:" />
                                <ComboBox fx:id="typeCombo" maxWidth="Infinity" prefHeight="35.0" promptText="Select Classification..." />
                            </children>
                        </VBox>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegisterLocation" prefHeight="35.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-cursor: hand;" text="Deploy Station Node" />
                    </children>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="10.0">
                    <children>
                        <Label text="System Infrastructure Network Layout" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TableView fx:id="locationTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colLocationId" prefWidth="80.0" text="Station ID" />
                                <TableColumn fx:id="colLocationName" prefWidth="160.0" text="Facility Label" />
                                <TableColumn fx:id="colCity" prefWidth="110.0" text="City" />
                                <TableColumn fx:id="colState" prefWidth="100.0" text="State/Region" />
                                <TableColumn fx:id="colType" prefWidth="100.0" text="Node Type" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>